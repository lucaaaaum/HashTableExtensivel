digraph HashTable {
    node [shape=plaintext];
    rankdir=LR;

    diretorio [label=<
        <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0">
            <TR><TD COLSPAN="1">Profundidade: 3</TD></TR>
            <TR><TD PORT="diretorio0">000</TD></TR>
            <TR><TD PORT="diretorio1">001</TD></TR>
            <TR><TD PORT="diretorio2">010</TD></TR>
            <TR><TD PORT="diretorio3">011</TD></TR>
            <TR><TD PORT="diretorio4">100</TD></TR>
            <TR><TD PORT="diretorio5">101</TD></TR>
            <TR><TD PORT="diretorio6">110</TD></TR>
            <TR><TD PORT="diretorio7">111</TD></TR>
       </TABLE>
    >];

    bucket0 [label=<
        <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0">
            <TR><TD COLSPAN="2">Bucket 0: Profundidade = 3</TD></TR>
            <TR><TD>Chave</TD><TD>Elemento</TD></TR>
            <TR><TD>Yurie Kokubu</TD><TD>I wanna be with you</TD></TR>
            <TR><TD></TD><TD></TD></TR>
        </TABLE>
    >];
    bucket1 [label=<
        <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0">
            <TR><TD COLSPAN="2">Bucket 1: Profundidade = 1</TD></TR>
            <TR><TD>Chave</TD><TD>Elemento</TD></TR>
            <TR><TD>Anri</TD><TD>Remember Summer Days</TD></TR>
            <TR><TD></TD><TD></TD></TR>
        </TABLE>
    >];
    bucket2 [label=<
        <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0">
            <TR><TD COLSPAN="2">Bucket 2: Profundidade = 2</TD></TR>
            <TR><TD>Chave</TD><TD>Elemento</TD></TR>
            <TR><TD></TD><TD></TD></TR>
            <TR><TD></TD><TD></TD></TR>
        </TABLE>
    >];
    bucket3 [label=<
        <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0">
            <TR><TD COLSPAN="2">Bucket 3: Profundidade = 3</TD></TR>
            <TR><TD>Chave</TD><TD>Elemento</TD></TR>
            <TR><TD>Tomoko Aran</TD><TD>Midnight Pretenders</TD></TR>
            <TR><TD>Cindy</TD><TD>Destiny</TD></TR>
        </TABLE>
    >];

    diretorio:diretorio0 -> bucket0
    diretorio:diretorio1 -> bucket1
    diretorio:diretorio2 -> bucket2
    diretorio:diretorio3 -> bucket1
    diretorio:diretorio4 -> bucket3
    diretorio:diretorio5 -> bucket1
    diretorio:diretorio6 -> bucket2
    diretorio:diretorio7 -> bucket1
}

digraph HashTable {
    node [shape=plaintext];
    rankdir=LR;

    diretorio [label=<
        <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0">
            <TR><TD COLSPAN="1">Profundidade: 3</TD></TR>
            <TR><TD PORT="diretorio0">000</TD></TR>
            <TR><TD PORT="diretorio1">001</TD></TR>
            <TR><TD PORT="diretorio2">010</TD></TR>
            <TR><TD PORT="diretorio3">011</TD></TR>
            <TR><TD PORT="diretorio4">100</TD></TR>
            <TR><TD PORT="diretorio5">101</TD></TR>
            <TR><TD PORT="diretorio6">110</TD></TR>
            <TR><TD PORT="diretorio7">111</TD></TR>
       </TABLE>
    >];

    bucket0 [label=<
        <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0">
            <TR><TD COLSPAN="2">Bucket 0: Profundidade = 2</TD></TR>
            <TR><TD>Chave</TD><TD>Elemento</TD></TR>
            <TR><TD>4</TD><TD>Pessoa</TD></TR>
            <TR><TD>8</TD><TD>Pessoa</TD></TR>
        </TABLE>
    >];
    bucket1 [label=<
        <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0">
            <TR><TD COLSPAN="2">Bucket 1: Profundidade = 3</TD></TR>
            <TR><TD>Chave</TD><TD>Elemento</TD></TR>
            <TR><TD>1</TD><TD>Pessoa</TD></TR>
            <TR><TD>9</TD><TD>Pessoa</TD></TR>
        </TABLE>
    >];
    bucket2 [label=<
        <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0">
            <TR><TD COLSPAN="2">Bucket 2: Profundidade = 2</TD></TR>
            <TR><TD>Chave</TD><TD>Elemento</TD></TR>
            <TR><TD>2</TD><TD>Pessoa</TD></TR>
            <TR><TD>6</TD><TD>Pessoa</TD></TR>
        </TABLE>
    >];
    bucket3 [label=<
        <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0">
            <TR><TD COLSPAN="2">Bucket 3: Profundidade = 2</TD></TR>
            <TR><TD>Chave</TD><TD>Elemento</TD></TR>
            <TR><TD>3</TD><TD>Pessoa</TD></TR>
            <TR><TD>7</TD><TD>Pessoa</TD></TR>
        </TABLE>
    >];
    bucket4 [label=<
        <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0">
            <TR><TD COLSPAN="2">Bucket 4: Profundidade = 3</TD></TR>
            <TR><TD>Chave</TD><TD>Elemento</TD></TR>
            <TR><TD>5</TD><TD>Pessoa</TD></TR>
            <TR><TD></TD><TD></TD></TR>
        </TABLE>
    >];

    diretorio:diretorio0 -> bucket0
    diretorio:diretorio1 -> bucket1
    diretorio:diretorio2 -> bucket2
    diretorio:diretorio3 -> bucket3
    diretorio:diretorio4 -> bucket0
    diretorio:diretorio5 -> bucket4
    diretorio:diretorio6 -> bucket2
    diretorio:diretorio7 -> bucket3
}

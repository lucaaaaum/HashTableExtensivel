            <TR><TD>2</TD><TD>Pessoa</TD></TR>
            <TR><TD>6</TD><TD>Pessoa</TD></TR>
        </TABLE>
    >];
    bucket4 [label=<
        <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0">
            <TR><TD COLSPAN="2">Bucket 4: Profundidade = 3</TD></TR>
            <TR><TD>Chave</TD><TD>Elemento</TD></TR>
            <TR><TD>4</TD><TD>Pessoa</TD></TR>
            <TR><TD>10</TD><TD>Pessoa</TD></TR>
        </TABLE>
    >];
    bucket5 [label=<
        <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0">
            <TR><TD COLSPAN="2">Bucket 5: Profundidade = 3</TD></TR>

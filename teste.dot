digraph HashTable {
    node [shape=plaintext];
    rankdir=LR;

    diretorio [label=<
        <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0">
            <TR><TD COLSPAN="1">Profundidade: 4</TD></TR>

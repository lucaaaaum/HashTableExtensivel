            <TR><TD></TD><TD></TD></TR>
            <TR><TD>8</TD><TD>Pessoa</TD></TR>
        </TABLE>
    >];
    bucket1 [label=<
        <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0">
            <TR><TD COLSPAN="2">Bucket 1: Profundidade = 2</TD></TR>
            <TR><TD>Chave</TD><TD>Elemento</TD></TR>
            <TR><TD>5</TD><TD>Pessoa</TD></TR>
            <TR><TD>9</TD><TD>Pessoa</TD></TR>
        </TABLE>
    >];
    bucket2 [label=<
        <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0">
            <TR><TD COLSPAN="2">Bucket 2: Profundidade = 3</TD></TR>
            <TR><TD>Chave</TD><TD>Elemento</TD></TR>
            <TR><TD>7</TD><TD>Pessoa</TD></TR>
            <TR><TD></TD><TD></TD></TR>
        </TABLE>
    >];
    bucket3 [label=<
        <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0">
            <TR><TD COLSPAN="2">Bucket 3: Profundidade = 2</TD></TR>
